# Committable template — copy to `.env` and fill in real values. The real `.env` is git-ignored.
# See README.md "Setup" / plan.md §6 for details.

# Get a key at https://platform.openai.com/api-keys (required for live agent runs + SDK traces).
OPENAI_API_KEY=sk-...

# Model the agents run on. This value is the source of truth; the code only falls back to a
# built-in default if it is unset. GPT-5-series / o-series are reasoning models (the code omits
# the `temperature` param for them automatically); gpt-4.x accept temperature=0.
OPENAI_MODEL=gpt-5.4-mini

# Tracing is ON by default (it powers the evidence packet); uncomment to disable dashboard upload.
# OPENAI_AGENTS_DISABLE_TRACING=1

# --- Optional: route agents to Claude via LiteLLM instead of OpenAI (see plan.md §6) ---
# ANTHROPIC_API_KEY=sk-ant-...
